# Sentinel — environment variable template
# Copy to `.env` (gitignored) and fill in actual values.
# Add a new line here whenever you add a new env var dependency. Keep .env.example in sync with .env keys.

# ----- App -----
# NODE_ENV=development              # or production
# APP_PORT=3000

# ----- Database (Postgres lean per decision 0006) -----
# DATABASE_URL=postgresql://user:password@localhost:5432/sentinel_dev

# ----- Auth (Phase 0) -----
# SESSION_SECRET=
# JWT_SECRET=

# ----- Observability -----
# SENTRY_DSN=
# LOG_LEVEL=info

# ----- AI / LLM (Phase 10 agents layer) -----
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# ----- Compliance / Regulator integrations (when needed) -----
# SSS_API_KEY=
# PHILHEALTH_API_KEY=
# PAGIBIG_API_KEY=
# BIR_API_KEY=
