# Sentinel — environment variable template
# Copy to `.env` (gitignored) and fill in actual values.
# Add a new line here whenever you add a new env var dependency. Keep .env.example in sync with .env keys.
# Every var below is validated at boot by core/loader.ts. Missing → fail fast with a clear message.

# ----- App -----
NODE_ENV=development                    # development | test | production
APP_PORT=3000

# ----- Database (Postgres per ADR 0006) -----
# Local dev (docker compose): postgres://sentinel:sentinel@postgres:5432/sentinel
# Host-side tools (drizzle-kit on your laptop): postgres://sentinel:sentinel@localhost:5432/sentinel
DATABASE_URL=postgres://sentinel:sentinel@localhost:5432/sentinel

# ----- Auth (modules/auth) -----
# Used to sign/verify session token integrity. 32+ random bytes. Generate: `openssl rand -hex 32`.
SESSION_SECRET=

# Super-admin bootstrap. If both are set on first migration, a super-admin user is seeded. Idempotent.
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=

# ----- Observability (wired starting Slice 1) -----
# SENTRY_DSN=
LOG_LEVEL=info

# ----- AI / LLM (Slice 7) -----
# OPENROUTER_API_KEY=

# ----- Compliance / Regulator integrations (when needed) -----
# SSS_API_KEY=
# PHILHEALTH_API_KEY=
# PAGIBIG_API_KEY=
# BIR_API_KEY=
